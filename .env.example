# ============================================================
# StarSoft backend — environment variables
# Copy to .env and fill in real values. NEVER commit .env.
# spring-dotenv reads .env automatically at startup.
# ============================================================



# --- Server ---
SERVER_PORT=8080

# --- Database ---
DB_HOST=localhost
DB_PORT=5433
DB_NAME=starsoft_db
DB_USER=starsoft_user
DB_PASSWORD=replace-with-strong-password
# Use 'update' in dev, 'validate' in production with managed migrations.
SPRING_JPA_DDL_AUTO=update

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6380

# --- JWT ---
# Generate with: openssl rand -base64 48
JWT_SECRET=replace-with-at-least-32-bytes-of-random-data
JWT_EXPIRATION=86400000

# --- CORS (comma-separated) ---
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://starsoft.az,https://www.starsoft.az

# --- Admin user (seeded on first run only) ---
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-strong-password
ADMIN_EMAIL=sarxanbabayevcontact@gmail.com
ADMIN_FULL_NAME=StarSoft Admin

# --- Rate limits ---
RATELIMIT_CONTACT_PER_HOUR=5
RATELIMIT_LOGIN_PER_MINUTE=10

# --- Mail (Gmail SMTP example — use an App Password, not your account password) ---
MAIL_ENABLED=true
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-sender@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_FROM=your-sender@gmail.com
MAIL_FROM_NAME=StarSoft
MAIL_NOTIFY_TO=sarxanbabayevcontact@gmail.com
